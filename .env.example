# ─────────────────────────────────────────────────────────────────────────────
# AI agent keys — used ONLY server-side by /api/chat.js
# ⚠️  NEVER prefix these with VITE_  — Vite bundles VITE_* vars into the public
#     browser code. These must stay server-side.
#
# Local dev:   copy this file to `.env.local`, fill in keys, run `vercel dev`
# Production:  add these in Vercel → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# Primary LLM — free tier from Google AI Studio: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Optional fallback LLM — free tier from Groq: https://console.groq.com/keys
GROQ_API_KEY=

# (Later, for voice) ElevenLabs — used only by the one-time audio-generation script,
# not at runtime. https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
